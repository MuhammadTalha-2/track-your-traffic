// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified        Boolean?  @default(false)
  refreshToken         String?
  refreshTokenExpires  DateTime?
}


model Visit {
  id           Int      @id @default(autoincrement())
  shop         String   @default("")
  source       String   @default("")
  medium       String   @default("")
  campaign     String   @default("")
  channel      String   @default("")
  landingPage  String   @default("") @map("landing_page")
  referrer     String   @default("")
  clickIdType  String   @default("") @map("click_id_type")
  visitorHash  String   @default("") @map("visitor_hash")
  campaignId   Int?     @map("campaign_id")
  createdAt    DateTime @default(now()) @map("created_at")

  // FK relation: visit → campaign
  campaignRef  Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([shop])
  @@index([shop, channel])
  @@index([shop, source])
  @@index([shop, createdAt])
  @@index([shop, visitorHash])
  @@index([shop, campaign])
  @@index([campaignId])
  @@map("tyt_visits")
}

model Campaign {
  id          Int       @id @default(autoincrement())
  shop        String    @default("")
  name        String    @default("")
  slug        String    @default("")
  source      String    @default("")
  medium      String    @default("")
  campaign    String    @default("")
  term        String    @default("")
  content     String    @default("")
  status      String    @default("active")
  goalVisits  Int       @default(0) @map("goal_visits")
  tags        String    @default("")
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  notes       String    @default("")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Reverse relation: campaign → visits
  visits      Visit[]

  @@unique([shop, slug])
  @@index([shop])
  @@index([shop, status])
  @@index([shop, campaign])
  @@index([shop, createdAt])
  @@map("tyt_campaigns")
}

model Setting {
  id        Int      @id @default(autoincrement())
  shop      String   @default("")
  key       String   @default("")
  value     String   @default("")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([shop, key])
  @@map("tyt_settings")
}